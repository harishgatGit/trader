# =============================================
# AI Stock Analyst Agent
# Environment Configuration
# =============================================

# Application
APP_ENV=local
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://trader:trader_pass@localhost:5432/trader_db

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Alpaca Configuration
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Email Alerts (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
EMAIL_FROM=AI Trader <your@email.com>

# Safety Settings
MAX_POSITION_SIZE_PERCENT=5
MAX_LOSS_PER_TRADE_PERCENT=2
MIN_RISK_REWARD=1.5

# JWT (for future auth)
JWT_SECRET=change_this_to_a_random_secret_string

# =============================================
# Video Generation Service
# =============================================
DISABLE_VIDEO_PIPELINE=false

# URL to the Python video generation microservice
VIDEO_SERVICE_URL=http://localhost:8090

# Shared API key between NestJS and Python video service
VIDEO_SERVICE_API_KEY=change-this-to-a-random-secret

# API key Python service uses when sending callbacks back to NestJS
CURRENT_APP_CALLBACK_API_KEY=change-this-to-another-random-secret

# Path to the Remotion project template (relative to video_agents_service)
REMOTION_PROJECT_PATH=./templates/remotion

# TTS Provider: 'edge' (free, no key needed), 'openai', or 'elevenlabs'
TTS_PROVIDER=edge

# Edge-TTS voice name
TTS_VOICE=en-US-ChristopherNeural

# Optional TTS API key for openai or elevenlabs
TTS_API_KEY=

